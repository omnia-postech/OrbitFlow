{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
      "vllm": {
        "class": "vllm.logging_utils.NewLineFormatter",
        "format": "%(levelname)s %(asctime)s %(filename)s:%(lineno)d] %(message)s",
        "datefmt": "%m-%d %H:%M:%S"
      }
    },
    "handlers": {
      "vllm": {
        "class": "logging.FileHandler",
        "formatter": "vllm",
        "level": "CRITICAL",
        "filename": "/home/xinyuema/vllm/outputs/benchmark/figure_4_2_token_deposit/Static1/figure_4_2_token_deposit/vllm_msg.log"
      }
    },
    "loggers": {
      "vllm": {
        "handlers": ["vllm"],
        "level": "DEBUG",
        "propagate": false
      }
    }
  }

  