{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
      "vllm": {
        "class": "vllm.logging_utils.NewLineFormatter",
        "format": "%(levelname)s %(asctime)s %(filename)s:%(lineno)d] %(message)s",
        "datefmt": "%m-%d %H:%M:%S"
      }
    },
    "handlers": {
      "vllm": {
        "class": "logging.FileHandler",
        "formatter": "vllm",
        "level": "CRITICAL",
        "filename": "/home/sychoy/vllm/outputs/benchmark/NotEnough/Static8/test_trace1_10_not_enough/vllm_msg.log"
      }
    },
    "loggers": {
      "vllm": {
        "handlers": ["vllm"],
        "level": "INFO",
        "propagate": false
      }
    }
  }

  