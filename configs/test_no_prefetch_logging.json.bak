{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
      "vllm": {
        "class": "vllm.logging_utils.NewLineFormatter",
        "format": "%(levelname)s %(asctime)s %(filename)s:%(lineno)d] %(message)s",
        "datefmt": "%m-%d %H:%M:%S"
      }
    },
    "handlers": {
      "vllm": {
        "class": "logging.FileHandler",
        "formatter": "vllm",
        "level": "INFO",
        "filename": "../outputs/test_no_prefetch/test_trace_contract_analysis_bimodal/vllm_msg_trace_contract_analysis_bimodal.log"
      }
    },
    "loggers": {
      "vllm": {
        "handlers": ["vllm"],
        "level": "INFO",
        "propagate": false
      }
    }
  }

  